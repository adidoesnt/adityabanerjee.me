---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Aditya Banerjee' } = Astro.props;
---

<html lang="en" data-theme="adityabanerjee">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body class="grid h-dvh grid-rows-[auto_1fr_auto] overflow-hidden">
		<header>
			<slot name="header" />
		</header>
		<main class="relative min-h-0 bg-base-100">
			<div class="wallpaper pointer-events-none absolute inset-0 z-0" aria-hidden="true"></div>
			<div class="relative z-10 flex h-full items-center justify-center overflow-y-auto p-4 md:p-10">
				<slot />
			</div>
		</main>
		<footer>
			<slot name="footer" />
		</footer>
	</body>
</html>

<style>
	.wallpaper {
		background-color: var(--color-base-300);
		opacity: 0.15;
		mask-image: url('/wallpaper-mark.jpg');
		mask-repeat: no-repeat;
		mask-position: center;
		mask-size: min(50vw, 50vh);
		mask-mode: luminance;
		-webkit-mask-image: url('/wallpaper-mark.jpg');
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-position: center;
		-webkit-mask-size: min(50vw, 50vh);
	}
</style>
