---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Aditya Banerjee' } = Astro.props;
---

<html lang="en" data-theme="adityabanerjee">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="grid min-h-screen grid-rows-[auto_1fr_auto]">
		<header>
			<slot name="header" />
		</header>
		<main class="p-4 md:p-10 grid place-items-center bg-base-100">
			<slot />
		</main>
		<footer>
			<slot name="footer" />
		</footer>
	</body>
</html>
