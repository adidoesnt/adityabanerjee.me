---
import SiteLayout from '../layouts/SiteLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { Briefcase, GraduationCap } from '@lucide/astro';
import { home } from '../content/home';
import { header as headerContent } from '../content/header';
---

<SiteLayout title="whoami | Aditya Banerjee">
	<Header slot="header" />
	<WindowFrame title="~/whoami" name="app-icon-whoami" closeHref="/" maximizable={false} class="w-full max-w-4xl">
		<div class="grid grid-cols-1 items-center gap-6 md:grid-cols-2">
			<div class="flex justify-center">
				<img
					src={home.displayImage}
					alt="Aditya Banerjee"
					class="border-base-100 border h-64 w-64 rounded-full object-cover md:h-80 md:w-80"
				/>
			</div>
			<div class="flex flex-col gap-4 text-center md:text-left">
				<h1 class="text-3xl font-bold md:text-4xl">{headerContent.name}</h1>
				<div class="border-base-300/40 text-base-content/70 flex flex-col gap-2 border-b pb-4 text-sm md:text-base">
					<div class="flex items-center justify-center gap-2 md:justify-start">
						<Briefcase class="text-primary h-4 w-4 shrink-0" />
						<span>{home.role}</span>
					</div>
					<div class="flex items-center justify-center gap-2 md:justify-start">
						<GraduationCap class="text-primary h-4 w-4 shrink-0" />
						<span>{home.education}</span>
					</div>
				</div>
				{home.tagline.map((line) => <p class="text-lg md:text-xl">{line}</p>)}
			</div>
		</div>
	</WindowFrame>
	<Footer slot="footer" />
</SiteLayout>
