---
import SiteLayout from '../layouts/SiteLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { featuredProjects, tooltips, fallbackDescription } from '../content/projects';

interface GithubRepo {
	name: string;
	description: string | null;
	html_url: string;
	fork: boolean;
	updated_at: string;
}

let allProjects: GithubRepo[] = [];
let fetchFailed = false;

// This site builds fully static (no SSR adapter), so this fetch runs once at
// build time and the result is baked into the deployed HTML — it won't pick up
// new repos until the next build. Move to a client-side fetch later if this
// needs to stay live between deploys.
try {
	const response = await fetch('https://api.github.com/users/adidoesnt/repos?per_page=100');
	if (!response.ok) throw new Error('Failed to fetch repositories from GitHub');
	const data = (await response.json()) as GithubRepo[];
	allProjects = data
		.filter((repo) => !repo.fork)
		.sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
} catch {
	fetchFailed = true;
}

const cardClass =
	'border-base-300/40 bg-base-200/70 rounded-xl border p-4 backdrop-blur-md transition-all duration-200 ease-out hover:-translate-y-1 hover:border-primary/60 hover:shadow-lg hover:shadow-black/30';
---

<SiteLayout title="Projects | Aditya Banerjee">
	<Header slot="header" />
	<WindowFrame title="~/projects.ls" class="w-full max-w-5xl">
		<div class="flex w-full flex-col items-center gap-12">
			<div class="flex w-full flex-col items-center gap-3">
				<h2 class="text-2xl font-semibold">Featured Projects</h2>
				<p class="text-base-content/50 text-sm">{tooltips.carousel}</p>
				<div class="flex w-full justify-center snap-x snap-mandatory gap-4 overflow-x-auto pt-2 pb-2">
					{
						featuredProjects.map((project, index) => (
							<button
								type="button"
								class={`${cardClass} featured-project-btn flex w-72 shrink-0 snap-center flex-col items-center text-center`}
								data-index={index}
								aria-label={`Show details for ${project.name}`}
							>
								<img
									src={project.imageSrc}
									alt=""
									class="bg-base-100 h-16 w-16 rounded-lg object-contain p-1"
								/>
								<h3 class="mt-3 text-lg font-semibold underline decoration-primary/60 underline-offset-4">
									{project.name}
								</h3>
								<p class="text-base-content/70 mt-2 text-sm">{project.description}</p>
							</button>
						))
					}
				</div>
			</div>

			<div class="flex w-full flex-col items-center gap-3">
				<h2 class="text-2xl font-semibold">All Projects</h2>
				<p class="text-base-content/50 text-sm">{tooltips.allProjects}</p>
				{
					fetchFailed ? (
						<p class="text-base-content/60 py-8">
							Unable to load projects right now. Please check back soon!
						</p>
					) : (
						<div class="grid w-full grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
							{allProjects.map((repo) => (
								<div class={`${cardClass} flex flex-col items-center gap-2 text-center`}>
									<a
										href={repo.html_url}
										target="_blank"
										rel="noopener noreferrer"
										class="hover:text-primary text-lg underline decoration-primary/60 underline-offset-4"
									>
										{repo.name}
									</a>
									<p class="text-base-content/70 text-sm">{repo.description ?? fallbackDescription}</p>
								</div>
							))}
						</div>
					)
				}
			</div>
		</div>
	</WindowFrame>
	<Footer slot="footer" />
</SiteLayout>

<dialog id="project-modal" class="modal">
	<div class="modal-box border-base-300/40 bg-base-200 border">
		<form method="dialog">
			<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
		</form>
		<div class="flex w-full items-center gap-3 pr-8">
			<img id="project-modal-image" alt="" class="bg-base-100 h-12 w-12 shrink-0 rounded-lg object-contain p-1" />
			<div class="flex flex-1 items-center justify-between gap-2">
				<h3 id="project-modal-title" class="text-xl font-semibold"></h3>
				<a id="project-modal-link" class="text-base-content/60 hover:text-primary font-mono text-sm" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
			</div>
		</div>
		<div id="project-modal-description" class="mt-4 flex flex-col gap-3 text-sm"></div>
	</div>
	<form method="dialog" class="modal-backdrop">
		<button>close</button>
	</form>
</dialog>

<script type="application/json" id="project-data" set:html={JSON.stringify(featuredProjects)} />

<script>
	interface FeaturedProject {
		name: string;
		href: string;
		imageSrc: string;
		description: string;
		longDescription: string[];
	}

	const dataEl = document.getElementById('project-data') as HTMLScriptElement;
	const projects: FeaturedProject[] = JSON.parse(dataEl.textContent ?? '[]');

	const modal = document.getElementById('project-modal') as HTMLDialogElement;
	const title = document.getElementById('project-modal-title') as HTMLElement;
	const link = document.getElementById('project-modal-link') as HTMLAnchorElement;
	const image = document.getElementById('project-modal-image') as HTMLImageElement;
	const description = document.getElementById('project-modal-description') as HTMLElement;

	document.querySelectorAll<HTMLButtonElement>('.featured-project-btn').forEach((button) => {
		button.addEventListener('click', () => {
			const index = Number(button.dataset.index);
			const project = projects[index];
			if (!project) return;

			title.textContent = project.name;
			link.href = project.href;
			image.src = project.imageSrc;
			image.alt = project.name;

			description.innerHTML = '';
			project.longDescription.forEach((paragraph) => {
				const p = document.createElement('p');
				p.innerHTML = paragraph;
				description.appendChild(p);
			});

			modal.showModal();
		});
	});
</script>
