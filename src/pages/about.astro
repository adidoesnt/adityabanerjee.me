---
import SiteLayout from '../layouts/SiteLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { about } from '../content/about';
---

<SiteLayout title="About | Aditya Banerjee">
	<Header slot="header" />
	<WindowFrame title="~/about.sh" name="app-icon-about" closeHref="/" class="w-full max-w-3xl">
		<div class="flex w-full flex-col items-center gap-4 md:gap-8">
			<div
				id="about-answer"
				class="border-base-300/40 bg-base-100/40 flex min-h-32 w-full flex-1 flex-col items-center justify-center gap-3 rounded-lg border p-4 text-center"
			>
				<svg
					id="about-icon"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.5"
					class="text-base-content/40 h-8 w-8"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z"
					></path>
				</svg>
				<span id="about-loading" class="loading loading-dots loading-md hidden"></span>
				<p id="about-answer-text" class="text-base-content/80 hidden text-lg"></p>
				<p id="about-answer-placeholder" class="text-base-content/60 text-lg">{about.info}</p>
			</div>

			<div class="flex w-full items-center gap-2">
				<input
					id="about-input"
					type="text"
					readonly
					value={about.info}
					class="border-base-300/40 bg-base-300/30 text-base-content/90 flex-1 rounded-lg border px-4 py-2 text-center font-mono text-sm md:text-base"
				/>
				<button
					id="about-submit"
					type="button"
					disabled
					aria-label="Submit"
					class="bg-primary text-primary-content flex h-10 w-10 shrink-0 items-center justify-center rounded-lg transition-opacity disabled:cursor-not-allowed disabled:opacity-40"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
						<path d="M2.94 2.94a1.5 1.5 0 0 1 1.632-.328l16.5 6.75a1.5 1.5 0 0 1 0 2.776l-16.5 6.75a1.5 1.5 0 0 1-2.049-1.81L4.36 12 2.523 4.922a1.5 1.5 0 0 1 .417-1.982Z"
						></path>
					</svg>
				</button>
			</div>

			<div class="flex flex-wrap items-center justify-center gap-2">
				{
					about.prompts.map((prompt) => (
						<button
							type="button"
							class="about-prompt-chip border-base-300/40 bg-base-200/70 hover:text-primary rounded-xl border px-3 py-1.5 text-sm backdrop-blur-md transition-all duration-200 ease-out hover:-translate-y-1 hover:border-primary/60 hover:shadow-lg hover:shadow-black/30"
							data-question={prompt.question}
						>
							{prompt.question}
						</button>
					))
				}
			</div>
		</div>
	</WindowFrame>
	<Footer slot="footer" />
</SiteLayout>

<script type="application/json" id="about-data" set:html={JSON.stringify(about.prompts)} />

<script>
	const dataEl = document.getElementById('about-data') as HTMLScriptElement;
	const prompts: { question: string; responses: string[] }[] = JSON.parse(dataEl.textContent ?? '[]');

	const input = document.getElementById('about-input') as HTMLInputElement;
	const submit = document.getElementById('about-submit') as HTMLButtonElement;
	const icon = document.getElementById('about-icon') as HTMLElement;
	const loading = document.getElementById('about-loading') as HTMLElement;
	const answerText = document.getElementById('about-answer-text') as HTMLParagraphElement;
	const placeholder = document.getElementById('about-answer-placeholder') as HTMLParagraphElement;
	const chips = document.querySelectorAll<HTMLButtonElement>('.about-prompt-chip');

	const delay = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

	let currentQuestion: string | null = null;

	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			currentQuestion = chip.dataset.question ?? null;
			input.value = currentQuestion ?? '';
			submit.disabled = false;
		});
	});

	submit.addEventListener('click', async () => {
		if (!currentQuestion || submit.disabled) return;
		const entry = prompts.find((prompt) => prompt.question === currentQuestion);
		if (!entry) return;

		submit.disabled = true;
		icon.classList.add('hidden');
		placeholder.classList.add('hidden');
		answerText.classList.add('hidden');
		answerText.textContent = '';
		loading.classList.remove('hidden');

		await delay(400);

		loading.classList.add('hidden');
		answerText.classList.remove('hidden');

		const response = entry.responses[Math.floor(Math.random() * entry.responses.length)];
		for (let i = 0; i < response.length; i++) {
			answerText.textContent += response[i];
			await delay(Math.random() * 20);
		}

		submit.disabled = false;
	});
</script>
