---
import SiteLayout from '../layouts/SiteLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Desktop from '../components/Desktop.astro';
---

<SiteLayout>
	<Header slot="header" />
	<script is:inline>
		if (!sessionStorage.getItem('desktop-booted')) {
			sessionStorage.setItem('desktop-booted', '1');
			location.replace('/whoami');
		}
	</script>
	<Desktop />
	<Footer slot="footer" />
</SiteLayout>
