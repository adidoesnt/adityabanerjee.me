---
import SiteLayout from '../layouts/SiteLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { home } from '../content/home';
---

<SiteLayout>
	<Header slot="header" />
	<WindowFrame title="~/Pictures/adi.jpg" class="w-full max-w-4xl">
		<div class="grid grid-cols-1 items-center gap-6 md:grid-cols-2">
			<div class="flex justify-center">
				<img
					src={home.displayImage}
					alt="Aditya Banerjee"
					class="border-base-100 border h-64 w-64 rounded-full object-cover md:h-80 md:w-80"
				/>
			</div>
			<div class="flex flex-col gap-4 text-center md:text-left">
				{home.tagline.map((line) => <p class="text-2xl md:text-3xl">{line}</p>)}
			</div>
		</div>
	</WindowFrame>
	<Footer slot="footer" />
</SiteLayout>
