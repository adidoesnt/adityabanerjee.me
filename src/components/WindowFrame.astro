---
interface Props {
	title?: string;
	class?: string;
}

const { title, class: className } = Astro.props;
---

<div
	class:list={[
		'border-base-300/40 bg-base-200/70 overflow-hidden rounded-2xl border shadow-2xl shadow-black/30 backdrop-blur-md',
		className,
	]}
>
	<div class="border-base-300/30 bg-base-100/30 relative flex h-9 items-center gap-2 px-4">
		<span class="bg-primary ring-base-100/20 h-3 w-3 rounded-full ring-1"></span>
		<span class="bg-secondary ring-base-100/20 h-3 w-3 rounded-full ring-1"></span>
		<span class="bg-accent ring-base-100/20 h-3 w-3 rounded-full ring-1"></span>
		{title && (
			<span
				class="text-base-content/50 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 font-mono text-xs tracking-wide"
			>
				{title}
			</span>
		)}
	</div>
	<div class="p-6 md:p-10">
		<slot />
	</div>
</div>
