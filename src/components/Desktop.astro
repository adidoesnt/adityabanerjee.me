---
import { apps } from '../content/apps';
import { isBlogEnabled } from '../lib/flags';
import AppIconTile from './AppIconTile.astro';

const visibleApps = apps.filter((app) => app.href !== '/blog' || isBlogEnabled);
---

<div class="relative h-full w-full">
	<!-- Mobile: springboard-style icon grid, centered -->
	<div class="flex h-full items-center justify-center md:hidden">
		<div class="grid grid-cols-4 gap-x-4 gap-y-6">
			{visibleApps.map((app) => <AppIconTile app={app} />)}
		</div>
	</div>

	<!-- Desktop: vertical column of icons, anchored top-right -->
	<div class="absolute right-0 top-0 hidden md:flex md:flex-col md:items-center md:gap-8">
		{visibleApps.map((app) => <AppIconTile app={app} />)}
	</div>
</div>
