---
import { header } from '../content/header';
---

<div
	class="border-base-300/40 bg-base-200/70 sticky top-0 z-10 flex h-14 items-center justify-between border-b px-4 text-lg backdrop-blur-md"
>
	<a href="/" class="flex items-center gap-2 text-xl font-semibold">
		<img src="/favicon-96x96.png" alt="" class="h-7 w-7 rounded-md" />
		{header.name}
	</a>
	<ul class="hidden gap-1 md:flex">
		{
			header.nav.map((link) => (
				<li>
					<a
						href={link.href}
						class="hover:bg-base-300/40 hover:text-primary after:bg-primary relative rounded px-2 py-1 transition-colors duration-150 after:absolute after:bottom-0.5 after:left-1/2 after:h-0.5 after:w-0 after:-translate-x-1/2 after:rounded-full after:transition-all after:duration-200 hover:after:w-2/3"
					>
						{link.label}
					</a>
				</li>
			))
		}
	</ul>
</div>
