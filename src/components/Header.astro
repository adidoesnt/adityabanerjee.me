---
import { header } from '../content/header';
---

<div
	class="border-base-300/40 bg-base-200/70 sticky top-0 z-10 flex h-14 items-center justify-between px-4 text-lg backdrop-blur-md"
>
	<a href="/" class="flex items-center gap-2 text-xl font-semibold">
		<img src="/favicon-96x96.png" alt="" class="h-7 w-7 rounded-md" />
		{header.name}
	</a>
	<span data-header-date class="text-base-content/60 font-mono text-sm">&nbsp;</span>
</div>

<script>
	let intervalId: number | undefined;

	function updateHeaderDate() {
		document.querySelectorAll<HTMLElement>('[data-header-date]').forEach((el) => {
			el.textContent = new Date().toLocaleString(undefined, {
				weekday: 'short',
				month: 'short',
				day: 'numeric',
				hour: 'numeric',
				minute: '2-digit',
			});
		});
	}

	function initHeaderDate() {
		updateHeaderDate();
		if (intervalId !== undefined) clearInterval(intervalId);
		intervalId = window.setInterval(updateHeaderDate, 30_000);
	}

	// Astro view transitions only execute a script's top-level code once per
	// session, even if the same script re-appears on a later navigation, so
	// the actual init logic has to live behind astro:page-load to rerun.
	document.addEventListener('astro:page-load', initHeaderDate);
</script>
