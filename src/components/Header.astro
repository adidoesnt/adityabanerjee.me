---
import { Search, UserRound, MessageCircleQuestionMark, History, FolderGit2, Rss, ListMusic } from '@lucide/astro';
import { header } from '../content/header';
import { apps, type AppIcon } from '../content/apps';
import { isBlogEnabled } from '../lib/flags';

const icons: Record<AppIcon, typeof Search> = {
	UserRound,
	MessageCircleQuestionMark,
	History,
	FolderGit2,
	Rss,
	ListMusic,
};

const searchApps = [
	...apps.filter((app) => app.href !== '/blog' || isBlogEnabled),
	{ id: 'playlist', label: 'playlist', href: '/playlist', icon: 'ListMusic' as const },
];
---

<div
	class="border-base-300/40 bg-base-200/70 sticky top-0 z-10 flex h-14 items-center justify-between px-4 text-lg backdrop-blur-md"
>
	<a href="/" class="flex items-center gap-2 text-xl font-semibold">
		<img src="/favicon-96x96.png" alt="" class="h-7 w-7 rounded-md" />
		{header.name}
	</a>
	<div class="flex items-center gap-3">
		<button
			type="button"
			id="app-search-toggle"
			aria-label="Search apps"
			class="text-base-content/60 hover:text-primary hidden items-center justify-center rounded p-1 transition-colors duration-150 md:flex"
		>
			<Search class="h-4 w-4" />
		</button>
		<span data-header-date data-compact="true" class="text-base-content/60 font-mono text-xs leading-none md:hidden">&nbsp;</span>
		<span data-header-date class="text-base-content/60 hidden font-mono text-sm leading-none md:inline">&nbsp;</span>
	</div>
</div>

<dialog id="app-search-modal" class="modal">
	<div class="modal-box border-base-300/40 bg-base-200 w-80 border p-2">
		<form method="dialog">
			<button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
		</form>
		<h3 class="px-4 pt-2 mb-3 text-xl font-semibold">Search</h3>
		<div class="px-2 pb-2">
			<input
				id="app-search-input"
				type="text"
				placeholder="Search apps..."
				autocomplete="off"
				class="border-base-300/40 bg-base-300/30 text-base-content/90 w-full rounded-lg border px-4 py-2 font-mono text-sm"
			/>
		</div>
		<ul>
			{
				searchApps.map((app) => {
					const Icon = icons[app.icon];
					return (
						<li data-app-search-row data-label={app.label.toLowerCase()}>
							<a
								href={app.href}
								data-app-search-item
								class="hover:bg-base-300/40 hover:text-primary flex items-center gap-3 rounded-lg px-4 py-2 transition-colors duration-150"
							>
								<Icon class="h-4 w-4 shrink-0" />
								<span>{app.label}</span>
							</a>
						</li>
					);
				})
			}
		</ul>
		<p id="app-search-empty" class="text-base-content/50 hidden px-4 py-6 text-center text-sm">No matches</p>
	</div>
	<form method="dialog" class="modal-backdrop">
		<button>close</button>
	</form>
</dialog>

<script>
	let intervalId: number | undefined;

	function updateHeaderDate() {
		const now = new Date();
		document.querySelectorAll<HTMLElement>('[data-header-date]').forEach((el) => {
			const compact = el.dataset.compact === 'true';
			el.textContent = now.toLocaleString(
				undefined,
				compact
					? { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }
					: { weekday: 'short', month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' },
			);
		});
	}

	function initHeaderDate() {
		updateHeaderDate();
		if (intervalId !== undefined) clearInterval(intervalId);
		intervalId = window.setInterval(updateHeaderDate, 30_000);
	}

	function initAppSearch() {
		const toggle = document.getElementById('app-search-toggle');
		const modal = document.getElementById('app-search-modal') as HTMLDialogElement | null;
		const input = document.getElementById('app-search-input') as HTMLInputElement | null;
		const rows = document.querySelectorAll<HTMLElement>('[data-app-search-row]');
		const empty = document.getElementById('app-search-empty');

		function filterResults() {
			const query = input?.value.trim().toLowerCase() ?? '';
			let anyVisible = false;
			rows.forEach((row) => {
				const matches = (row.dataset.label ?? '').includes(query);
				row.classList.toggle('hidden', !matches);
				if (matches) anyVisible = true;
			});
			empty?.classList.toggle('hidden', anyVisible);
		}

		toggle?.addEventListener('click', () => {
			if (input) input.value = '';
			filterResults();
			modal?.showModal();
			input?.focus();
		});

		input?.addEventListener('input', filterResults);

		input?.addEventListener('keydown', (event) => {
			if (event.key !== 'Enter') return;
			const firstVisible = document.querySelector<HTMLAnchorElement>(
				'[data-app-search-row]:not(.hidden) [data-app-search-item]',
			);
			firstVisible?.click();
		});

		document.querySelectorAll<HTMLAnchorElement>('[data-app-search-item]').forEach((link) => {
			link.addEventListener('click', () => modal?.close());
		});
	}

	// Astro view transitions only execute a script's top-level code once per
	// session, even if the same script re-appears on a later navigation, so
	// the actual init logic has to live behind astro:page-load to rerun.
	document.addEventListener('astro:page-load', initHeaderDate);
	document.addEventListener('astro:page-load', initAppSearch);
</script>
